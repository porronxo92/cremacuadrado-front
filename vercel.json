{
  "buildCommand": "npm run build:prod",
  "outputDirectory": "dist/cremacuadrado/browser",
  "installCommand": "npm install",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://cremacuadrado-back.vercel.app/api/:path*"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
